{
  "name": "xun",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'),p=require('path'),d='dist';fs.readdirSync(d).filter(f=>f.endsWith('.js')).forEach(f=>{const fp=p.join(d,f);fs.writeFileSync(fp,fs.readFileSync(fp,'utf8').replace(/^export /gm,''))})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check": "tsc --noEmit && vitest run"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.0",
    "happy-dom": "^20.8.9",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "web-ext": "^10.1.0"
  }
}
